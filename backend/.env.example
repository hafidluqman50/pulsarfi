# Server
LISTEN_ADDR=:8080
APP_ENV=development

# Database
DATABASE_URL=postgresql://user:password@host:5432/pulsarfi

# Auth
JWT_SECRET=change-me-to-a-long-random-string

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app

# Ethereum / Arbitrum Sepolia
ALCHEMY_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/your-key
IDRX_ADDRESS=0x03b53A71C5517907006EAb512A31C1eD5a56Ae64
UNISWAP_V2_FACTORY=0x4254378E95dBD9816a1a18428A81B4E1fBe5C296

# Email (Resend)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=notify@pulsarfi.xyz
RESEND_FROM_NAME=PulsarFi

# Supabase Storage (for KYC documents)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3
SUPABASE_S3_ACCESS_KEY=your-access-key
SUPABASE_S3_SECRET_KEY=your-secret-key
SUPABASE_S3_REGION=ap-southeast-1
SUPABASE_STORAGE_BUCKET=kyc-documents
